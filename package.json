{
  "name": "ipv-cri-check-hmrc-api",
  "description": "",
  "type": "module",
  "workspaces": [
    "integration-tests",
    "lambdas/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "unit": "export POWERTOOLS_DEV=true && vitest run",
    "test": "npm run unit --",
    "test:coverage": "export POWERTOOLS_DEV=true && vitest run --coverage",
    "sam:validate": "cd infrastructure && sam validate && sam validate --lint",
    "sam:build": "npm run sam:validate && sam build --template infrastructure/template.yaml --cached --parallel",
    "deploy": "./deploy.sh"
  },
  "dependencies": {
    "@aws-lambda-powertools/commons": "2.31.0",
    "@aws-lambda-powertools/parameters": "2.31.0",
    "@aws-lambda-powertools/tracer": "2.31.0",
    "@aws-sdk/client-dynamodb": "3.1012.0",
    "@aws-sdk/client-ssm": "3.1012.0",
    "@govuk-one-login/cri-audit": "1.0.2",
    "@govuk-one-login/cri-error-response": "1.0.0",
    "@govuk-one-login/cri-logger": "1.0.0",
    "@govuk-one-login/cri-metrics": "1.0.1",
    "esbuild": "0.28.0",
    "jose": "6.2.2"
  },
  "devDependencies": {
    "@aws-sdk/lib-dynamodb": "3.1012.0",
    "@aws-sdk/util-dynamodb": "3.996.2",
    "@govuk-one-login/cri-types": "^1.0.1",
    "@types/aws-lambda": "^8.10.126",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "10.0.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "vitest": "^4.1.3"
  }
}
