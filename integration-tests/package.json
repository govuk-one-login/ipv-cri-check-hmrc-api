{
  "name": "check-hmrc-api-integration-tests",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:api": "vitest run --config ./vitest.config.ts",
    "test:api:ci": "vitest run --config ./vitest.config.ci.ts",
    "start:contract": "cd api-gateway/contract && ts-node ./app.ts",
    "test:contract": "wait-on tcp:127.0.0.1:3000 && vitest run --config ./vitest.config.contract.ts",
    "test:contract:ci": "npm-run-all -p -r start:contract test:contract",
    "deploy": "../deploy.sh",
    "compile": "tsc"
  },
  "devDependencies": {
    "@aws-lambda-powertools/logger": "2.31.0",
    "@aws-sdk/client-kms": "3.1012.0",
    "@aws-sdk/client-secrets-manager": "3.1012.0",
    "@aws-sdk/credential-providers": "3.1012.0",
    "@govuk-one-login/cri-test-resources-helpers": "1.0.2",
    "@pact-foundation/pact": "16.3.0",
    "@types/express": "4.17.21",
    "@types/uuid": "9.0.8",
    "aws-sigv4-fetch": "4.4.1",
    "express": "4.22.1",
    "express-asyncify": "2.1.2",
    "jose": "5.10.0",
    "npm-run-all2": "8.0.4",
    "uuid": "8.3.2",
    "wait-on": "8.0.3"
  }
}
